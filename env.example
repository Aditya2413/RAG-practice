# RAG Chatbot Environment Configuration
# Copy this to .env and update values as needed

# ============= Environment =============
ENVIRONMENT=development
DEBUG=true

# ============= API Configuration =============
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============= LLM Configuration =============
# Options: "openai", "local"
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# Replace with your actual OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# ============= Embedding Configuration =============
# Options: "openai", "sentence-transformers"
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDING_DIMENSION=768

# ============= Vector Database Configuration =============
# Options: "chroma", "faiss", "pinecone", "qdrant"
VECTOR_DB_TYPE=chroma

# Chroma Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# FAISS Configuration
FAISS_INDEX_PATH=./data/faiss_index

# Pinecone Configuration (if using Pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=production
PINECONE_INDEX_NAME=rag-index

# Qdrant Configuration (if using Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_documents
QDRANT_PREFER_GRPC=false

# ============= Document Processing =============
CHUNK_SIZE=512
CHUNK_OVERLAP=51
CHUNK_STRATEGY=recursive

# ============= Retrieval Configuration =============
RETRIEVAL_TYPE=similarity
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# Hybrid Search Configuration
HYBRID_SEARCH_ENABLED=false
KEYWORD_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7

# ============= Memory Configuration =============
CONVERSATION_MEMORY_TYPE=buffer
MAX_MEMORY_MESSAGES=10
ENABLE_QUERY_REWRITING=true

# ============= Cache Configuration =============
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600

# ============= Logging Configuration =============
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_pipeline.log

# ============= File Upload Configuration =============
UPLOAD_DIRECTORY=./data/uploads
MAX_FILE_SIZE_MB=100

# ============= Database Configuration =============
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=rag_chatbot

# ============= Performance Configuration =============
BATCH_SIZE=32
NUM_THREADS=4
ENABLE_GPU=false

# ============= Feature Flags =============
ENABLE_RERANKING=false
ENABLE_QUERY_EXPANSION=false
ENABLE_SEMANTIC_CHUNKING=false

# ============= Evaluation Configuration =============
ENABLE_EVALUATION_METRICS=true
SAVE_EVALUATION_RESULTS=true
EVALUATION_OUTPUT_DIR=./data/evaluation_results
